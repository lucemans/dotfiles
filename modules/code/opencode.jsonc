{
    "$schema": "https://opencode.ai/config.json",
    "permission": {
        "read": {
            "*.sops.yaml": "deny",
            "*.sops.yml": "deny"
        }
    },
    "mcp": {
        "playwright": {
            "type": "local",
            "command": ["opencode-playwright-mcp"],
            "enabled": true
        }
    },
    "agent": {
	"visual-qa": {
          "description": "Uses Playwright to inspect running frontend features, navigate the browser, capture screenshots, and review visual design quality gives harsh design feedback to ensure consistency pleasability to the eye, and the end-user's needs. Read-only on source code.",
	  "mode": "subagent",
	  "model": "openai/gpt-5.5",
	  "permission": {
            "edit": "deny",
	    "write": "deny",
	    "bash": "ask",
	    "playwright_*": "allow"
	  }
	}
    }
}
