{
    "$schema": "https://opencode.ai/config.json",
    "theme": "system",
    "permission": {
        "read": {
            "*.sops.yaml": "deny",
            "*.sops.yml": "deny"
        },
        "edit": {
            "/home/luc/.cargo/registry/src/**": "deny"
        },
        "external_directory": {
            "/home/luc/.cargo/registry/src/**": "allow"
        },
        "playwright_*": "deny",
        "playwright_browser_run_code_unsafe": "deny",
        "bash": {
            "*": "ask",

            "git": "deny",
            "git *": "deny",
            "*git *": "deny",

            "git status": "allow",
            "git status *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "git show": "allow",
            "git show *": "allow",
            "git branch --show-current": "allow",
            "git rev-parse": "allow",
            "git rev-parse *": "allow",
            "git remote -v": "allow",
            "git ls-files": "allow",
            "git ls-files *": "allow",
            "git blame *": "allow",
            "git reflog": "allow",
            "git reflog *": "allow",

            "pnpm build": "allow",
            "pnpm typecheck": "allow",
            "pnpm lint": "allow",

            "direnv*": "deny",
            "*direnv*": "deny",
            "gpg*": "deny",
            "*gpg*": "deny",
            "pgp*": "deny",
            "*pgp*": "deny",
            "gnupg*": "deny",
            "*gnupg*": "deny"
        }
    },
    "instructions": ["AGENTS.md", "~/.config/opencode/rules/TYPESCRIPT.md"],
    "share": "disabled",
    "autoupdate": "notify",
    "snapshot": true,
    "tool_output": {
        "max_lines": 1500,
        "max_bytes": 98304
    },
    "compaction": {
        "tail_turns": 12
    },
    "mcp": {
        "playwright": {
            "type": "local",
            "command": ["opencode-playwright-mcp"],
            "enabled": false
        }
    },
    "provider": {
        
    }
}
