{
    "$schema": "https://opencode.ai/config.json",
    "theme": "system",
    "permission": {
        "read": {
            "*.sops.yaml": "deny",
            "*.sops.yml": "deny"
        },
        "edit": {
            "/home/luc/.cargo/registry/src/**": "deny"
        },
        "external_directory": {
            "/home/luc/.cargo/registry/src/**": "allow"
        },
        "bash": {
            "*": "ask",

            "git": "deny",
            "git *": "deny",
            "*git *": "deny",

            "git status": "allow",
            "git status *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "git show": "allow",
            "git show *": "allow",
            "git branch --show-current": "allow",
            "git rev-parse": "allow",
            "git rev-parse *": "allow",
            "git remote -v": "allow",
            "git ls-files": "allow",
            "git ls-files *": "allow",
            "git blame *": "allow",
            "git reflog": "allow",
            "git reflog *": "allow",

            "pnpm build": "allow",
            "pnpm typecheck": "allow",
            "pnpm lint": "allow",

            "direnv*": "deny",
            "*direnv*": "deny",
            "gpg*": "deny",
            "*gpg*": "deny",
            "pgp*": "deny",
            "*pgp*": "deny",
            "gnupg*": "deny",
            "*gnupg*": "deny"
        }
    },
    "instructions": ["AGENTS.md"],
    "lsp": {
        "lua": {
            "command": ["lua-language-server"],
            "extensions": [".lua"]
        },
        "markdown": {
            "command": ["marksman", "server"],
            "extensions": [".md", ".markdown"]
        },
        "mdx": {
            "command": ["mdx-language-server", "--stdio"],
            "extensions": [".mdx"]
        },
        "taplo": {
            "command": ["taplo", "lsp", "stdio"],
            "extensions": [".toml"]
        },
        "json": {
            "command": ["vscode-json-language-server", "--stdio"],
            "extensions": [".json", ".jsonc"]
        },
        "html": {
            "command": ["vscode-html-language-server", "--stdio"],
            "extensions": [".html", ".htm"]
        },
        "css": {
            "command": ["vscode-css-language-server", "--stdio"],
            "extensions": [".css", ".scss", ".less"]
        },
        "yaml-ls": {
            "command": ["yaml-language-server", "--stdio"]
        }
    },
    "share": "disabled",
    "autoupdate": "notify",
    "snapshot": true,
    "tool_output": {
        "max_lines": 1500,
        "max_bytes": 98304
    },
    "compaction": {
        "tail_turns": 12
    },
    "provider": {
        
    }
}
