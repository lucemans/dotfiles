// Place your key bindings in this file to override the defaults
[
	{
		"key": "shift+f6",
		"command": "editor.action.rename",
		"when": "editorTextFocus"
	},
	{
		"key": "ctrl+shift+0",
		"command": "workbench.action.gotoSymbol"
	},
	{
		"key": "ctrl+shift+o",
		"command": "-workbench.action.gotoSymbol"
	},
	{
		"key": "ctrl+shift+alt+o",
		"command": "chat.action.askQuickQuestion",
		"when": "hasChatProvider"
	},
	{
		"key": "ctrl+shift+alt+i",
		"command": "-chat.action.askQuickQuestion",
		"when": "hasChatProvider"
	},
	{
		"key": "ctrl+shift+alt+i",
		"command": "editor.action.formatDocument.none",
		"when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
	},
	{
		"key": "ctrl+shift+i",
		"command": "-editor.action.formatDocument.none",
		"when": "editorTextFocus && !editorHasDocumentFormattingProvider && !editorReadonly"
	},
	{
		"key": "ctrl+shift+alt+i",
		"command": "supermaven.addToChat"
	},
	{
		"key": "ctrl+shift+i",
		"command": "-supermaven.addToChat"
	},
	{
		"key": "ctrl+shift+l",
		"command": "aichat.newchataction"
	},
	{
		"key": "ctrl+l",
		"command": "-aichat.newchataction"
	},
	{
		"key": "ctrl+shift+;",
		"command": "editor.action.clipboardCutAction",
		"when": "editorTextFocus && !editorReadonly"
	},
	{
		"key": "ctrl+l",
		"command": "-editor.action.clipboardCutAction",
		"when": "editorTextFocus && !editorReadonly"
	},
	{
		"key": "ctrl+l",
		"command": "expandLineSelection",
		"when": "textInputFocus"
	},
	{
		"key": "ctrl+p",
		"command": "-expandLineSelection",
		"when": "textInputFocus"
	},
	{
		"key": "ctrl+shift+alt+l",
		"command": "controlPanel.openControlPanel"
	},
	{
		"key": "ctrl+shift+i",
		"command": "-controlPanel.openControlPanel"
	},
	{
		"key": "ctrl+shift+i",
		"command": "editor.action.formatDocument"
	},
	{
		"key": "ctrl+k ctrl+d",
		"command": "-editor.action.formatDocument"
	},
	{
		"key": "ctrl+shift+i",
		"command": "editor.action.codeAction",
		"args": {
			"kind": "source.addMissingImports",
			"apply": "ifSingle"
		},
		"when": "editorHasCodeActionsProvider && editorTextFocus && !editorReadonly"
	},
	{
		"key": "ctrl+i",
		"command": "composerMode.agent"
	},
	// 1) TS/TSX: remove unused imports → organize imports → format
	{
		"key": "ctrl+shift+o",
		"command": "runCommands",
		"args": {
			"commands": [
				"typescript.removeUnusedImports",
				"editor.action.organizeImports",
				"editor.action.formatDocument"
			]
		},
		"when": "editorLangId == 'typescript' || editorLangId == 'typescriptreact'"
	},
	// 2) Rust: organize imports → format
	{
		"key": "ctrl+shift+o",
		"command": "runCommands",
		"args": {
			"commands": [
				"editor.action.organizeImports",
				"rust-analyzer.organizeImports",
				"editor.action.formatDocument"
			]
		},
		"when": "editorLangId == 'rust'"
	},
	// 3) ESLint‑fixable (TS/JS/JSON/etc): eslint.autofix → format
	{
		"key": "ctrl+shift+o",
		"command": "runCommands",
		"args": {
			"commands": [
				"eslint.executeAutofix",
				"editor.action.formatDocument"
			]
		},
		"when": "editorLangId =~ /^(javascript|javascriptreact|json|jsonc|typescript|typescriptreact)$/"
	}
]